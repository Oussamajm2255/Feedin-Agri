# ============================================
# Smart Farm Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!

# ── Database ──────────────────────────────────
# PostgreSQL connection URL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Set to 'true' only during initial setup to auto-create tables
DB_SYNCHRONIZE=false

# Set to 'true' to auto-run pending migrations on startup
DB_MIGRATIONS_RUN=false

# ── JWT Authentication ────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<minimum-32-character-random-string>

# Must be DIFFERENT from JWT_SECRET
REFRESH_JWT_SECRET=<different-minimum-32-character-random-string>

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
# In production: https://feedingreen.up.railway.app
# In development: http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# ── MQTT (IoT Sensor Communication) ──────────
MQTT_BROKER=mqtt://broker-url:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Logging ───────────────────────────────────
# Options: error, warn, log, debug, verbose
LOG_LEVEL=debug
